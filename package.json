{
  "name": "pulseverse",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web:clear": "expo start --web --clear",
    "web:dev": "npm run dev --prefix web",
    "site:dev": "npm run dev --prefix web",
    "app:web": "expo start --web",
    "db:link": "npx supabase link",
    "db:migrate": "npx supabase db push",
    "db:push": "npx supabase db push",
    "launch:notes": "node -e \"console.log('See docs/LAUNCH_RUNBOOK.md')\"",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "eas:build:dev": "eas build --profile development",
    "eas:build:dev:ios": "eas build --profile development --platform ios",
    "eas:build:dev:android": "eas build --profile development --platform android",
    "eas:build:beta": "eas build --profile beta",
    "eas:build:beta:ios": "eas build --profile beta --platform ios",
    "eas:build:beta:android": "eas build --profile beta --platform android",
    "eas:build:production": "eas build --profile production",
    "eas:build:production:ios": "eas build --profile production --platform ios",
    "eas:build:production:android": "eas build --profile production --platform android",
    "eas:submit:production:ios": "eas submit --profile production --platform ios --latest",
    "eas:builds": "node scripts/eas-recent-builds.mjs",
    "eas:log:ios": "node scripts/eas-log-submission.mjs ios",
    "eas:log:android": "node scripts/eas-log-submission.mjs android",
    "typecheck": "tsc --noEmit",
    "test:webhook-delivery": "npx --yes deno@2 test --config supabase/functions/_shared/webhook-delivery/deno.json supabase/functions/_shared/webhook-delivery/delivery.test.ts",
    "smoke": "npm run typecheck && npm run test && npm run db:types:check",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 250",
    "db:types": "node scripts/gen-supabase-types.mjs",
    "db:types:check": "node scripts/check-db-types-fresh.mjs",
    "worker:media": "node scripts/creator-media-worker.mjs",
    "assets:pride-border": "node scripts/process-pride-border.mjs",
    "assets:solstice-borders": "node scripts/process-summer-solstice-borders.mjs",
    "assets:app-icon": "node scripts/build-app-icon.cjs",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^14.0.0",
    "@expo/vector-icons": "^15.0.3",
    "@livekit/react-native": "^2.10.3",
    "@livekit/react-native-expo-plugin": "^1.0.2",
    "@livekit/react-native-webrtc": "^144.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.0",
    "@vercel/analytics": "^2.0.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "expo-video": "~3.0.16",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.11",
    "livekit-client": "^2.19.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-compressor": "^1.16.0",
    "react-native-css-interop": "^0.2.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-iap": "^14.4.0",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.5.1",
    "tailwindcss": "^3.3.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@flydotio/dockerfile": "^0.7.10",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^10.0.0",
    "jimp": "^1.6.1",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  },
  "private": true
}
