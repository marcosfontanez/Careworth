# PulseVerse RC / QA — staging Supabase only (NOT production)
# Copy to `.env.staging.local` (gitignored) for device QA + script env.
#
# Supabase Dashboard → Pulse Verse Staging → Project Settings → API
#   Project URL       → EXPO_PUBLIC_SUPABASE_URL / STAGING_SUPABASE_URL
#   anon public       → EXPO_PUBLIC_SUPABASE_ANON_KEY / STAGING_SUPABASE_ANON_KEY
#   service_role      → STAGING_SUPABASE_SERVICE_KEY (scripts only — never commit)
#
# Do NOT use sakrlbmzmfvdywqgyqxh (production) for RC QA.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_staging_anon_key

# Used by scripts/seed-staging-rc-users.mjs and scripts/staging-rc-smoke.mjs
STAGING_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
STAGING_SUPABASE_ANON_KEY=your_staging_anon_key
STAGING_SUPABASE_SERVICE_KEY=your_staging_service_role_key
# STAGING_CRON_SECRET=your_staging_circle_prompts_cron_secret

# Optional — keep aligned with preview/beta builds; sponsored flags stay OFF in code.
# EXPO_PUBLIC_LIVE_STREAMING=1
