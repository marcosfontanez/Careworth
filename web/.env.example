# Public (browser + server)
# Required for auth + admin console (/admin/login): get values from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Optional — leading dot shares session cookies across subdomains (e.g. apex + app). Must match
# where users sign in; use only in production when marketing and Expo web share one Supabase project.
# NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN=.your-domain.com
# Used for metadataBase, sitemap, and Open Graph when set (strongly recommended in production)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Expo web build URL embedded at /web-app (no trailing slash). In Supabase → Authentication → URL
# Configuration: keep BOTH marketing + app origins in Redirect URLs, e.g. https://your-domain.com/**
# and https://app.your-domain.com/** (plus www/local). Adding only the app URL often breaks /login.
NEXT_PUBLIC_EXPO_WEB_APP_URL=

# Public contact emails (mailto + support center)
NEXT_PUBLIC_SUPPORT_EMAIL=support@your-domain.com
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@your-domain.com
# Optional — security.txt + responsible disclosure (defaults to security@your-domain if unset)
NEXT_PUBLIC_SECURITY_EMAIL=security@your-domain.com

# Optional — pepper for hashing partner API secrets (change in production).
PARTNER_API_KEY_PEPPER=

# Optional — global rate limits (admin API + marketing forms). Falls back to in-memory if unset.
# Create a Redis database at https://upstash.com and paste REST credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — error tracking (see src/instrumentation.ts)
SENTRY_DSN=

# Optional — CSP violation reports (production only). Must be present at *build* time so Next can
# bake `report-uri` into the Content-Security-Policy header (see src/lib/content-security-policy.ts).
# Use Sentry → Settings → Security Headers, or any HTTPS endpoint that accepts CSP reports.
CSP_REPORT_URI=

# Server-only — required for admin dashboard/insights (bypasses RLS after staff auth in `proxy.ts`).
# Also used for marketing contact + newsletter inserts (never expose to the client).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
