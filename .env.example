# PulseVerse mobile (Expo) — environment variables
# Copy to `.env.local` for local dev (gitignored). Production: Expo → EAS → Environment variables.
# Full launch steps: docs/LAUNCH_RUNBOOK.md

# --- Required (production) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# --- Live (optional — eas.json sets LIVE_STREAMING=1; needs LiveKit for real video) ---
# EXPO_PUBLIC_LIVE_STREAMING=1
EXPO_PUBLIC_LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud

# --- Observability (recommended) ---
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_SENTRY_ENABLE_DEV=0

# --- Legal / marketing URLs (optional — opens browser from Settings) ---
# EXPO_PUBLIC_MARKETING_SITE=https://pulseverse.app
# EXPO_PUBLIC_TERMS_URL=https://pulseverse.app/terms
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://pulseverse.app/privacy

# --- Video export worker (optional) ---
# EXPO_PUBLIC_VIDEO_EXPORT_URL=https://your-export-worker.example.com

# --- Contact addresses (mailto + in-app legal) ---
# See docs/OPERATIONAL_EMAIL_ADDRESSES.md
EXPO_PUBLIC_SUPPORT_EMAIL=support@pulseverse.app
EXPO_PUBLIC_PRIVACY_EMAIL=privacy@pulseverse.app
EXPO_PUBLIC_LEGAL_EMAIL=legal@pulseverse.app
EXPO_PUBLIC_SECURITY_EMAIL=security@pulseverse.app
EXPO_PUBLIC_CHILD_SAFETY_EMAIL=safety@pulseverse.app

# --- Spotify (optional) ---
# EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
