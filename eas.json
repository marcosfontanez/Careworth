{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_LIVE_STREAMING": "1",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_LIVE_STREAMING": "1",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_LIVE_STREAMING": "1",
        "EXPO_PUBLIC_LIVE_DISCOVERY_DEMOS": "0",
        "EXPO_PUBLIC_LIVE_CLIP_EGRESS": "1",
        "EXPO_PUBLIC_CREATOR_BROLL_STUDIO": "1",
        "EXPO_PUBLIC_CREATOR_OVERLAY_PIP": "1",
        "EXPO_PUBLIC_CREATOR_GREEN_SCREEN_STUDIO": "1",
        "EXPO_PUBLIC_CREATOR_CUTOUT_OVERLAY": "1",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "beta": {
      "distribution": "internal",
      "channel": "beta",
      "environment": "preview",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_LIVE_STREAMING": "1",
        "EXPO_PUBLIC_LIVE_FEED_INJECTION": "1",
        "EXPO_PUBLIC_FEED_CLIPPING": "1",
        "EXPO_PUBLIC_FEED_CREATOR_GIFTING": "1",
        "EXPO_PUBLIC_LIVE_DISCOVERY_DEMOS": "0",
        "EXPO_PUBLIC_LIVE_CLIP_EGRESS": "1",
        "EXPO_PUBLIC_CREATOR_BROLL_STUDIO": "1",
        "EXPO_PUBLIC_CREATOR_OVERLAY_PIP": "1",
        "EXPO_PUBLIC_CREATOR_GREEN_SCREEN_STUDIO": "1",
        "EXPO_PUBLIC_CREATOR_CUTOUT_OVERLAY": "1",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "environment": "production",
      "node": "20.19.4",
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "android": {
        "image": "latest"
      },
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=8192",
        "EXPO_PUBLIC_LIVE_STREAMING": "1",
        "EXPO_PUBLIC_LIVE_DISCOVERY_DEMOS": "0",
        "EXPO_PUBLIC_CREATOR_BROLL_STUDIO": "1",
        "EXPO_PUBLIC_CREATOR_OVERLAY_PIP": "1",
        "EXPO_PUBLIC_CREATOR_GREEN_SCREEN_STUDIO": "1",
        "EXPO_PUBLIC_CREATOR_CUTOUT_OVERLAY": "1",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "GF8CJ5XZB8",
        "ascAppId": "6765962116"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services.json",
        "track": "internal"
      }
    }
  }
}
